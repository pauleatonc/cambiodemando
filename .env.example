# =============================================================================
# cambiodemando - Variables de entorno
# =============================================================================
# Desarrollo: usar con docker-compose.yml (DJANGO_SETTINGS_MODULE=...dev)
# Producción: usar con docker-compose-prod.yml; definir SECRET_KEY y ALLOWED_HOSTS reales
# =============================================================================

# Django
DJANGO_SETTINGS_MODULE=cambiodemando.settings.dev
SECRET_KEY=dev-secret-key-cambiodemando-cambiar-en-produccion

# Base de datos (PostgreSQL)
# En Docker el servicio web usa DB_HOST=db para conectar al contenedor postgres
DB_HOST=db
DB_PORT=5432
POSTGRES_DB=cambiodemando
POSTGRES_USER=cambiodemando
POSTGRES_PASSWORD=cambiodemando

# Producción (solo para docker-compose-prod; descomentar y ajustar en prod)
# ALLOWED_HOSTS=localhost,.tudominio.com
# SECRET_KEY=generar-clave-segura-50-caracteres-minimo

# Contacto
CONTACT_EMAIL=contacto@cambiodemando.cl

# Redes sociales (Síguenos; si están vacíos no se muestra el bloque)
# SOCIAL_INSTAGRAM_URL=https://www.instagram.com/cambio_de_mando/
# SOCIAL_TWITTER_URL=

# AdSense
ADSENSE_CLIENT=
ADSENSE_SLOT_INLINE_TOP=
ADSENSE_SLOT_INLINE_BOTTOM=
ADSENSE_SLOT_RAIL_LEFT=
ADSENSE_SLOT_RAIL_RIGHT=

# Google Analytics 4 (ID de medición, p. ej. G-XXXXXXXXXX)
# GA_MEASUREMENT_ID=

# Publicaciones diarias / Instagram
SITE_BASE_URL=http://localhost:8000http://localhost:8000
PUBLIC_MEDIA_BASE_URL=http://localhost:8000
INSTAGRAM_BASE_URL=https://graph.facebook.com/v22.0
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_IG_USER_ID=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
# facebook_exchange (Graph API con cuenta profesional vía Facebook Login)
# instagram_refresh (Instagram Graph host graph.instagram.com)
# disabled (sin refresh automático)
INSTAGRAM_REFRESH_MODE=facebook_exchange
INSTAGRAM_REFRESH_THRESHOLD_DAYS=7
# Caption de la imagen en Instagram. Si no se define, se usa el texto por defecto (invita a votar + días + resultado + disclaimer).
# Variables: {dias} {good_pct} {bad_pct} {result_label}
# INSTAGRAM_CAPTION_TEMPLATE=¿Cómo vamos? Bien: {good_pct}% | Mal: {bad_pct}% | Resultado: {result_label}
INSTAGRAM_CAPTION_TEMPLATE=
DAILY_POST_HOUR=12
DAILY_POST_MINUTE=0